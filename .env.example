PORT=5000
DATABASE_URL="postgresql://user:password@localhost:5432/classnote_db?schema=public"
JWT_SECRET="genera_un_string_aleatorio_de_64_caracteres"

# Integraciones de IA (orden de prioridad para transcripción)
# Groq: Ultrarrápido (1-3 seg), gratuito en tier básico
GROQ_API_KEY=""
# Deepgram: Ultrarrápido (2-5 seg), tiene tier gratuito
DEEPGRAM_API_KEY=""
# OpenAI Whisper: Rápido (10-30 seg)
OPENAI_API_KEY=""
# Gemini: Alternativa, puede fallar con archivos grandes
GEMINI_API_KEY=""

# Firebase Admin SDK
FIREBASE_PRIVATE_KEY_PATH="firebase-key.json"

# Google OAuth 2.0 (para Google Sign-In sin Firebase)
# Obtener desde: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""

# Cloud Storage (AWS S3) - Opcional
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET_NAME=""
